# Raw API response cache — debugging artifact, not redistributable.
# Also used for proprietary inputs that are NOT redistributed (e.g.
# CME GF feeder-cattle settles in /data/raw/cme/ — see LICENSE-DATA.md
# for the redistribution posture).
/data/raw/
!/data/raw/.gitkeep

# Quarto build output
_site/
.quarto/
_freeze/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
renv/library/
renv/local/
renv/cellar/
renv/staging/

# Jupyter
.ipynb_checkpoints/

# Environment + secrets
.env
.env.local
*.secret

# OS cruft
.DS_Store
Thumbs.db

# Editor state
.vscode/
.idea/
*.swp
*.swo

# Internal working docs — kept locally, not tracked in the public repo.
# Pulled out 2026-04-22 pending explicit approvals to publish.
DECISIONS_LOG.md
PHASE1_PLAN.md

# Local research-data scratch folders — never committed.
# Glob covers any top-level `Data_<source>/` directory the user keeps for
# their own working files (raw API pulls, third-party files licensed for
# personal review only, etc.). The public repo sources Clovis directly
# from USDA-AMS (public-domain) and treats CME futures as link-out only.
# See LICENSE-DATA.md for the redistribution policy.
Data_*/

# Internal planning docs (Phase-0 Decision 7 — kept local until promotion)
PLAN_*.md

# Generated download artifacts (CSV + XLSX produced by scripts/prepare_downloads.py
# at site-build time alongside each canonical *.parquet; bundled into _site by
# Quarto's `resources:` config). Never committed; regenerated on every build.
data/processed/*.csv
data/processed/*.xlsx
